---
layout: null
permalink: /search-publications.json
---
[
  {% for pub in site.data.publications %}
  {
    "title" : "{{ pub.title | escape }}",
    "text"  : "{{ pub.text | escape }}",
    "tags"  : "{{ pub.tags | join:'|' | append:'|' }}",
    "year"  : "{{ pub.year }}",
    "url"   : "#{{ pub.title | slugify }}"
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]